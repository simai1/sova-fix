# Sova-Fix — общий .env для локальной разработки (Docker Compose в корне)
# Скопируй в .env (`cp .env.example .env`) и заполни секреты.

# === Общие ===
NODE_ENV=development

# === API (api/) ===
PORT=3000
API_URL=http://localhost:3000
WEB_URL=http://localhost:3002

# Любые случайные строки для dev — НЕ переиспользовать на проде.
# Сгенерировать новые: `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
COOKIE_KEY=dev-cookie-key-change-me
MASTER_API_KEY=dev-master-api-key

# === БД (используется и postgres-контейнером, и api) ===
DB_USER=postgres
DB_PWD=root
DB_HOST=db                          # имя контейнера postgres в docker-сети
DB_PORT=5432
DB_NAME=sovafix_dev

# === Email (Resend) — опционально, можно оставить пустым ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# === Telegram-бот для self-binding TG_ID (web-LK → бот через deep-link) ===
# Username бота без @, под TG-grammar (5..32 alnum/_, начинается с буквы).
TG_BOT_USERNAME=sova_fix_bot

# === Bot (bot/) ===
# Тестовый токен от @BotFather. Без него bot-контейнер не стартует —
# но он спрятан за compose-profile "bot", по умолчанию не запускается.
BOT_TOKEN=
WEBSOKET_URL=ws://server:3000/      # ws до api в docker-сети (имя контейнера = server)

# === Bot proxy (если Telegram заблокирован у провайдера) ===
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_LOGIN=
PROXY_PASSWORD=
PROXY_TYPE=socks5

# === Frontend (front/) — Vite читает свой front/.env.development.local ===
# (этот файл фронту не нужен; перечислено для полноты картины)
# VITE_API_URL=http://localhost:3000
# VITE_WEB_URL=http://localhost:3002
# VITE_OBJECTS_LIMIT=null
# VITE_UNITS_LIMIT=3
# VITE_PICTURE_NAME=sovaTechLogo.svg
# VITE_GLOBAL_OPEN_TO_BLOCK=open
# VITE_GLOBAL_OPEN_REPORT_BLOCK=open
