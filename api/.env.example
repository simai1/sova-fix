PORT=3000
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001

#JWT section
# 64+ random bytes (например `openssl rand -hex 64`); НЕ использовать одно
# значение для access и refresh — компрометация одного секрета не должна
# обнулять второй фактор.
JWT_ACCESS_SECRET=__CHANGE_ME__
JWT_REFRESH_SECRET=__CHANGE_ME__

#Cookie section
# 64+ random bytes; используется cookie-session как HMAC-ключ.
COOKIE_KEY=__CHANGE_ME__

#Api Key
# 32+ random bytes; единый pre-shared-секрет между ботом/intеграциями и API.
MASTER_API_KEY=__CHANGE_ME__

#DB section
DB_USER=postgres
DB_PWD=root
DB_HOST=localhost
DB_PORT=5432
DB_NAME=name

#Email section
MAIL_USER=username
MAIL_HOST=host
MAIL_PASS=password
